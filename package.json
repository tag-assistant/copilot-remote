{
  "name": "copilot-remote",
  "version": "0.8.0",
  "description": "Control GitHub Copilot CLI from Telegram. Send prompts from your phone, get streamed responses with tool calls, session persistence, and model selection.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "copilot-remote": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ && prettier --check 'src/**/*.ts'",
    "lint:fix": "eslint src/ --fix && prettier --write 'src/**/*.ts'",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/cli.js",
    "test": "node --test dist/**/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "copilot",
    "github-copilot",
    "telegram",
    "remote",
    "cli",
    "agent",
    "coding-agent",
    "ai"
  ],
  "author": "tag-assistant",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tag-assistant/copilot-remote.git"
  },
  "homepage": "https://github.com/tag-assistant/copilot-remote#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.1.32",
    "@grammyjs/runner": "^2.0.3",
    "grammy": "^1.41.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
